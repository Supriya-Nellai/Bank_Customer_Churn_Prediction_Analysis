      <table>
        <view>
          <datasources>
            <datasource caption='Churn_Modelling' name='federated.01wbtom0cnwgri158qc4219m59vm' />
          </datasources>
          <datasource-dependencies datasource='federated.01wbtom0cnwgri158qc4219m59vm'>
            <column caption='Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_0400796457160704]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Exited]) / COUNT([Exited])' />
            </column>
            <column caption='Credit Score Band' datatype='string' name='[Calculation_0400796457705474]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [CreditScore] &lt; 500 THEN &quot;Poor&quot;&#13;&#10;&#13;&#10;ELSEIF [CreditScore] &lt; 650 THEN &quot;Fair&quot;&#13;&#10;&#13;&#10;ELSEIF [CreditScore] &lt; 750 THEN &quot;Good&quot;&#13;&#10;&#13;&#10;ELSE &quot;Excellent&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Credit Score' datatype='integer' name='[CreditScore]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Exited]' role='measure' type='quantitative' />
