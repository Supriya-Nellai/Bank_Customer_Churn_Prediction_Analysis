      <aliases enabled='yes' />
      <column caption='Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_0400796457160704]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Exited]) / COUNT([Exited])' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_0400796457570305]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 30 THEN &quot;18-29&quot;&#13;&#10;&#13;&#10;ELSEIF [Age] &lt; 40 THEN &quot;30-39&quot;&#13;&#10;&#13;&#10;ELSEIF [Age] &lt; 50 THEN &quot;40-49&quot;&#13;&#10;&#13;&#10;ELSEIF [Age] &lt; 60 THEN &quot;50-59&quot;&#13;&#10;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Credit Score Band' datatype='string' name='[Calculation_0400796457705474]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [CreditScore] &lt; 500 THEN &quot;Poor&quot;&#13;&#10;&#13;&#10;ELSEIF [CreditScore] &lt; 650 THEN &quot;Fair&quot;&#13;&#10;&#13;&#10;ELSEIF [CreditScore] &lt; 750 THEN &quot;Good&quot;&#13;&#10;&#13;&#10;ELSE &quot;Excellent&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Member Status' datatype='string' name='[Calculation_0400796457803779]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [IsActiveMember]=1 THEN &quot;Active&quot;&#13;&#10;&#13;&#10;ELSE &quot;Inactive&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Credit Card Status' datatype='string' name='[Calculation_0400796457902084]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [HasCrCard]=1 THEN &quot;Has Credit Card&quot;&#13;&#10;&#13;&#10;ELSE &quot;No Credit Card&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_0400796459147269]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([CustomerId])' />
      </column>
      <column caption='Total Churned' datatype='integer' name='[Calculation_0400796463513606]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Exited])' />
      </column>
      <column caption='One' datatype='integer' name='[Calculation_0400796492701703]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
